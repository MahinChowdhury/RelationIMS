{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=RelationIMS;Username=postgres;Password=password",
    "HangfireConnection": "Host=localhost;Port=5432;Database=RelationIMS;Username=postgres;Password=password"
  },
  "Finbuckle": {
    "MultiTenant": {
      "Stores": {
        "ConfigurationStore": {
          "Tenants": [
            {
              "Id": "tenant-relationims",
              "Identifier": "RelationIms",
              "Name": "Relation IMS",
              "ConnectionString": "Host=localhost;Port=5432;Database=RelationIMS;Username=postgres;Password=password"
            },
            {
              "Id": "tenant-yoloims",
              "Identifier": "YoloIms",
              "Name": "Yolo IMS",
              "ConnectionString": "Host=localhost;Port=5432;Database=YoloIMS;Username=postgres;Password=password"
            }
          ]
        }
      }
    }
  },
  "JwtSettings": {
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "Issuer": "JWTDemoApi"
  },
  "MinIO": {
    "Endpoint": "minio:9000",
    "PublicBaseUrl": "",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "product-images",
    "UseSSL": false
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "AllowedCorsOrigins": "http://localhost:4200,http://localhost:5173,https://localhost:5173",
  "ImageUpload": {
    "MaxDegreeOfParallelism": 4
  }
}