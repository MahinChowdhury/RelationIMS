# ============================================
# Relation IMS - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=RelationIMS
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=your_redis_password_here

# MinIO Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=product-images
MINIO_USE_SSL=false

# JWT
JWT_ISSUER=JWTDemoApi
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS (comma-separated origins)
ALLOWED_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# PgAdmin (optional - only used with 'tools' profile)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
