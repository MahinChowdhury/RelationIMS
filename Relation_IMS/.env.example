# ============================================
# Relation_IMS — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For production, copy to .env.production:
#   cp .env.example .env.production
#
# NEVER commit .env or .env.production to source control.
# ============================================

# PostgreSQL
POSTGRES_DB=RelationIMS
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# Redis
REDIS_PORT=6379

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
STORAGE_BLOB_URI=http://azurite:10000/devstoreaccount1
STORAGE_QUEUE_URI=http://azurite:10001/devstoreaccount1
STORAGE_TABLE_URI=http://azurite:10002/devstoreaccount1

# JWT
JWT_ISSUER=JWTDemoApi
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4200,http://localhost:5173

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
API_PORT=8080
