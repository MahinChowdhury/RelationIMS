# Production Environment Variables
# These are loaded when running `npm run build`
# DO NOT commit sensitive values - these are safe for public repos since they're build-time constants

# API Configuration - Relative path (use full URL if API is on different domain)
# For same-domain deployment: /api/v1
# For different domain: https://api.yourdomain.com
VITE_API_URL=/api/v1

# Client ID for JWT authentication
VITE_CLIENT_ID=client-app-one
